{
  "metadata": {
    "id": "vercel-light",
    "name": "Vercel Light",
    "description": "Vercel light theme - Ported from vscode-vercel-theme",
    "version": "1.0.0",
    "variant": "light",
    "tags": ["light", "vercel", "minimal"]
  },
  "colors": {
    "primary": {
      "base": "#0070F3",
      "hover": "#0062D1",
      "active": "#52A8FF",
      "foreground": "#ffffff",
      "muted": "#0070F380",
      "emphasis": "#52A8FF"
    },
    "surface": {
      "background": "#FFFFFF",
      "foreground": "#171717",
      "muted": "#FFFFFF",
      "mutedForeground": "#666666",
      "elevated": "#FFFFFF",
      "elevatedForeground": "#171717",
      "overlay": "#00000020",
      "subtle": "#FFFFFF"
    },
    "interactive": {
      "border": "#EAEAEA",
      "borderHover": "#999999",
      "borderFocus": "#0070F3",
      "selection": "#0000000a",
      "selectionForeground": "#171717",
      "focus": "#0070F3",
      "focusRing": "#0070F340",
      "cursor": "#171717",
      "hover": "#00000008",
      "active": "#00000010"
    },
    "status": {
      "error": "#E5484D",
      "errorForeground": "#ffffff",
      "errorBackground": "#E5484D20",
      "errorBorder": "#E5484D50",
      "warning": "#FFB224",
      "warningForeground": "#ffffff",
      "warningBackground": "#FFB22420",
      "warningBorder": "#FFB22450",
      "success": "#46A758",
      "successForeground": "#ffffff",
      "successBackground": "#46A75820",
      "successBorder": "#46A75850",
      "info": "#0070F3",
      "infoForeground": "#ffffff",
      "infoBackground": "#0070F320",
      "infoBorder": "#0070F350"
    },
    "pr": {
      "open": "#46A758",
      "draft": "#888888",
      "blocked": "#FFB224",
      "merged": "#8E4EC6",
      "closed": "#E5484D"
    },
    "syntax": {
      "base": {
        "background": "#FFFFFF",
        "foreground": "#171717",
        "comment": "#888888",
        "keyword": "#E93D82",
        "string": "#46A758",
        "number": "#FFB224",
        "function": "#8E4EC6",
        "variable": "#171717",
        "type": "#12A594",
        "operator": "#E93D82"
      },
      "tokens": {
        "commentDoc": "#888888",
        "stringEscape": "#46A758",
        "keywordImport": "#E93D82",
        "storageModifier": "#E93D82",
        "functionCall": "#8E4EC6",
        "method": "#8E4EC6",
        "variableProperty": "#0070F3",
        "variableOther": "#0070F3",
        "variableGlobal": "#0070F3",
        "variableLocal": "#FAFAFA",
        "parameter": "#171717",
        "constant": "#FFB224",
        "class": "#8E4EC6",
        "className": "#8E4EC6",
        "interface": "#12A594",
        "struct": "#8E4EC6",
        "enum": "#FFB224",
        "typeParameter": "#12A594",
        "namespace": "#0070F3",
        "module": "#E93D82",
        "tag": "#E93D82",
        "jsxTag": "#E93D82",
        "tagAttribute": "#FFB224",
        "tagAttributeValue": "#46A758",
        "boolean": "#FFB224",
        "decorator": "#8E4EC6",
        "label": "#E93D82",
        "punctuation": "#171717",
        "macro": "#8E4EC6",
        "preprocessor": "#E93D82",
        "regex": "#12A594",
        "url": "#0070F3",
        "key": "#FFB224",
        "exception": "#E5484D"
      },
      "highlights": {
        "diffAdded": "#46A758",
        "diffAddedBackground": "#E6F9E9",
        "diffRemoved": "#E5484D",
        "diffRemovedBackground": "#FDECED",
        "diffModified": "#0070F3",
        "diffModifiedBackground": "#EBF8FF",
        "lineNumber": "#666666",
        "lineNumberActive": "#171717"
      }
    },
    "markdown": {
      "heading1": "#8E4EC6",
      "heading2": "#8E4EC6",
      "heading3": "#8E4EC6",
      "heading4": "#8E4EC6",
      "link": "#0070F3",
      "linkHover": "#52A8FF",
      "inlineCode": "#46A758",
      "inlineCodeBackground": "#FAFAFA",
      "blockquote": "#666666",
      "blockquoteBorder": "#EAEAEA",
      "listMarker": "#0070F399"
    },
    "chat": {
      "userMessage": "#171717",
      "userMessageBackground": "#ffffff",
      "assistantMessage": "#171717",
      "assistantMessageBackground": "#ffffff",
      "timestamp": "#888888",
      "divider": "#EAEAEA"
    },
    "tools": {
      "background": "#ffffff80",
      "border": "#EAEAEA9d",
      "headerHover": "#FAFAFA",
      "icon": "#888888",
      "title": "#171717",
      "description": "#666666",
      "edit": {
        "added": "#46A758",
        "addedBackground": "#E6F9E9",
        "removed": "#E5484D",
        "removedBackground": "#FDECED",
        "lineNumber": "#666666"
      }
    }
  },
  "config": {
    "fonts": {
      "sans": "system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, monospace",
      "heading": "system-ui, -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "radius": {
      "none": "0",
      "sm": "2px",
      "md": "4px",
      "lg": "6px",
      "xl": "8px",
      "full": "9999px"
    },
    "transitions": {
      "fast": "150ms ease",
      "normal": "250ms ease",
      "slow": "350ms ease"
    }
  }
}
